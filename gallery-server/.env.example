# Bearer token the desktop app sends with every admin request.
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=your-secret-admin-token-here

# Port the HTTP server listens on. 8787 matches `wrangler dev` so existing
# Worker docs / tunnel configs stay portable.
PORT=8787

# Where photo bytes, gallery metadata, and feedback land on disk. Back this
# directory up if you care about your galleries — there's no other store.
# Resolved relative to the working directory if not absolute.
DATA_DIR=./data
